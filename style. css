* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    scroll-behavior: smooth;
}

body {
    background: #0f172a;
    color: #f8fafc;
    overflow-x: hidden; /* Prevents accidental horizontal scrolling */
}

span { color: #0ea5e9; }

/* Fixed Header Fix */
header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    padding: 20px 10%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(15, 23, 42, 0.95);
    backdrop-filter: blur(8px); /* Gives a premium, blurred glass effect */
    z-index: 100;
}

.logo { font-size: 24px; font-weight: bold; }

nav a { color: white; text-decoration: none; margin-left: 20px; transition: 0.3s; }
nav a:hover { color: #0ea5e9; }

section { padding: 120px 10% 40px; min-height: 100vh; }

/* Hero Section Layout */
.hero { 
    display: flex; 
    align-items: center; 
    justify-content: space-between; 
    gap: 40px; 
}

.hero-content h1 { font-size: 48px; margin: 10px 0; line-height: 1.2; }
.hero-content h2 { color: #94a3b8; margin-bottom: 15px; }
.hero-content p { color: #94a3b8; max-width: 500px; line-height: 1.6; }

.btn { 
    display: inline-block; 
    margin-top: 20px; 
    padding: 12px 28px; 
    background: #0ea5e9; 
    color: #0f172a; 
    text-decoration: none; 
    font-weight: bold; 
    border-radius: 6px; 
    transition: 0.3s ease;
}
.btn:hover { box-shadow: 0 0 15px rgba(14, 165, 233, 0.4); }

/* Responsive Image Fix */
.hero-img img { 
    width: 300px; 
    height: 300px; 
    max-width: 100%; /* Ensures it never stretches wider than the screen */
    border-radius: 50%; 
    border: 5px solid #0ea5e9; 
    object-fit: cover; 
}

.heading { text-align: center; font-size: 36px; margin-bottom: 40px; }

.skills-container { display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; }
.skill-box { background: #1e293b; padding: 20px 40px; border-radius: 10px; text-align: center; min-width: 150px; }
.skill-box i { font-size: 40px; color: #0ea5e9; margin-bottom: 10px; }

.project-card { background: #1e293b; padding: 30px; border-radius: 10px; max-width: 600px; margin: 0 auto; }
.tech { color: #0ea5e9; margin-bottom: 15px; font-weight: 500; }
.project-card ul { margin-left: 20px; color: #94a3b8; line-height: 1.8; }

.edu-box { background: #1e293b; padding: 25px; border-radius: 10px; max-width: 600px; margin: 0 auto; }
.edu-box p { color: #94a3b8; margin-top: 5px; }

footer { text-align: center; padding: 20px; background: #020617; color: #64748b; margin-top: 40px; }

/* Enhanced Mobile Optimization */
@media (max-width: 768px) {
    header { padding: 15px 5%; }
    section { padding: 100px 5% 40px; }
    .hero { flex-direction: column-reverse; text-align: center; gap: 20px; }
    .hero-content h1 { font-size: 34px; }
    .hero-img img { width: 220px; height: 220px; } /* Scales down perfectly on mobile phones */
    nav { display: none; }
}


